# Copy to .env and fill. install.sh reads this and bakes it into a
# systemd EnvironmentFile with mode 0600 (never committed).

# A fine-grained PAT with Contents: read+write on this repo only.
GITHUB_TOKEN=

# Repo coordinates. Override if you fork.
GITHUB_OWNER=azzon
GITHUB_REPO=slate-akshare-mirror

# Optional knobs:
# AKSHARE_MIRROR_DAYS_BACK=30      # backfill N past days (slow)
# AKSHARE_MIRROR_SKIP_FINANCIALS=1 # skip the ~30-40 min financials pass
# AKSHARE_MIRROR_SKIP_PUSH=1       # dry run
